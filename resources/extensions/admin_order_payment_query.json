{
    "target_layout": "admin_ecommerce_order_detail",
    "injections": [
        {
            "target_id": "tab_content_area",
            "position": "append_child",
            "components": [
                {
                    "id": "nicepay_verify_panel",
                    "type": "basic",
                    "name": "Div",
                    "if": "{{(order.data?.payments?.filter(p => p.transaction_id) ?? []).length > 0}}",
                    "props": {
                        "className": "card"
                    },
                    "children": [
                        {
                            "id": "nicepay_verify_header",
                            "type": "basic",
                            "name": "Div",
                            "props": { "className": "flex items-center gap-2 mb-4" },
                            "children": [
                                {
                                    "type": "basic",
                                    "name": "Div",
                                    "props": { "className": "w-1.5 h-4 bg-blue-500 rounded-full flex-shrink-0" }
                                },
                                {
                                    "type": "basic",
                                    "name": "H3",
                                    "props": { "className": "text-sm font-semibold text-gray-800 dark:text-gray-200" },
                                    "text": "$t:sirsoft-pay-nicepayments.admin.order_verify_title"
                                },
                                {
                                    "type": "basic",
                                    "name": "Span",
                                    "props": { "className": "text-xs text-gray-400 dark:text-gray-500 hidden sm:inline" },
                                    "text": "$t:sirsoft-pay-nicepayments.admin.order_verify_description"
                                }
                            ]
                        },
                        {
                            "id": "nicepay_payments_list",
                            "type": "basic",
                            "name": "Div",
                            "props": { "className": "space-y-3" },
                            "iteration": {
                                "source": "{{order.data?.payments?.filter(p => p.transaction_id) ?? []}}",
                                "item_var": "payment",
                                "index_var": "pIdx"
                            },
                            "children": [
                                {
                                    "type": "basic",
                                    "name": "Div",
                                    "props": { "className": "rounded-lg border border-gray-100 dark:border-gray-700 p-3 bg-gray-50 dark:bg-gray-800/50" },
                                    "children": [
                                        {
                                            "type": "basic",
                                            "name": "Div",
                                            "props": { "className": "flex flex-wrap items-center gap-3" },
                                            "children": [
                                                {
                                                    "type": "basic",
                                                    "name": "Div",
                                                    "props": { "className": "flex-1 min-w-0" },
                                                    "children": [
                                                        {
                                                            "type": "basic",
                                                            "name": "Span",
                                                            "props": { "className": "text-xs text-gray-500 dark:text-gray-400 block mb-0.5" },
                                                            "text": "TID"
                                                        },
                                                        {
                                                            "type": "basic",
                                                            "name": "Span",
                                                            "props": { "className": "font-mono text-xs text-gray-900 dark:text-gray-100 break-all block" },
                                                            "text": "{{payment.transaction_id}}"
                                                        }
                                                    ]
                                                },
                                                {
                                                    "type": "basic",
                                                    "name": "Button",
                                                    "props": {
                                                        "disabled": "{{_local._nicepayQuerying && _local._nicepayActiveTid === payment.transaction_id}}",
                                                        "className": "flex items-center gap-1.5 px-3 py-1.5 text-xs font-medium bg-blue-600 hover:bg-blue-700 text-white rounded-md transition-colors disabled:opacity-50 disabled:cursor-not-allowed whitespace-nowrap flex-shrink-0"
                                                    },
                                                    "actions": [
                                                        {
                                                            "type": "click",
                                                            "handler": "sequence",
                                                            "actions": [
                                                                {
                                                                    "handler": "setState",
                                                                    "params": {
                                                                        "target": "local",
                                                                        "_nicepayQuerying": true,
                                                                        "_nicepayActiveTid": "{{payment.transaction_id}}",
                                                                        "_nicepayResult": null,
                                                                        "_nicepayError": null
                                                                    }
                                                                },
                                                                {
                                                                    "handler": "apiCall",
                                                                    "auth_required": true,
                                                                    "target": "/api/plugins/sirsoft-pay-nicepayments/admin/transaction/query",
                                                                    "params": {
                                                                        "method": "POST",
                                                                        "body": {
                                                                            "tid": "{{_local._nicepayActiveTid}}"
                                                                        }
                                                                    },
                                                                    "onSuccess": [
                                                                        {
                                                                            "handler": "setState",
                                                                            "params": {
                                                                                "target": "local",
                                                                                "_nicepayQuerying": false,
                                                                                "_nicepayResult": "{{$response.data}}"
                                                                            }
                                                                        }
                                                                    ],
                                                                    "onError": [
                                                                        {
                                                                            "handler": "setState",
                                                                            "params": {
                                                                                "target": "local",
                                                                                "_nicepayQuerying": false,
                                                                                "_nicepayError": "$t:sirsoft-pay-nicepayments.admin.order_verify_error"
                                                                            }
                                                                        }
                                                                    ]
                                                                }
                                                            ]
                                                        }
                                                    ],
                                                    "children": [
                                                        {
                                                            "type": "basic",
                                                            "name": "Icon",
                                                            "if": "{{_local._nicepayQuerying && _local._nicepayActiveTid === payment.transaction_id}}",
                                                            "props": { "name": "spinner", "className": "w-3 h-3 animate-spin" }
                                                        },
                                                        {
                                                            "type": "basic",
                                                            "name": "Span",
                                                            "text": "$t:sirsoft-pay-nicepayments.admin.order_verify_button"
                                                        }
                                                    ]
                                                }
                                            ]
                                        },
                                        {
                                            "type": "basic",
                                            "name": "Div",
                                            "if": "{{_local._nicepayActiveTid === payment.transaction_id && _local._nicepayError}}",
                                            "props": { "className": "mt-2 text-xs text-red-600 dark:text-red-400 bg-red-50 dark:bg-red-900/20 rounded px-2 py-1.5" },
                                            "text": "{{_local._nicepayError}}"
                                        },
                                        {
                                            "id": "nicepay_verify_result",
                                            "type": "basic",
                                            "name": "Div",
                                            "if": "{{_local._nicepayActiveTid === payment.transaction_id && _local._nicepayResult}}",
                                            "props": { "className": "mt-3 pt-3 border-t border-gray-200 dark:border-gray-700" },
                                            "children": [
                                                {
                                                    "type": "basic",
                                                    "name": "Div",
                                                    "props": { "className": "flex items-center gap-2 mb-3" },
                                                    "children": [
                                                        {
                                                            "type": "basic",
                                                            "name": "Span",
                                                            "if": "{{_local._nicepayResult.PayStatus === '0'}}",
                                                            "props": { "className": "inline-flex items-center px-2 py-0.5 rounded-full text-xs font-semibold bg-green-100 text-green-800 dark:bg-green-900/30 dark:text-green-300" },
                                                            "text": "$t:sirsoft-pay-nicepayments.admin.pay_status_approved"
                                                        },
                                                        {
                                                            "type": "basic",
                                                            "name": "Span",
                                                            "if": "{{_local._nicepayResult.PayStatus === '1'}}",
                                                            "props": { "className": "inline-flex items-center px-2 py-0.5 rounded-full text-xs font-semibold bg-gray-100 text-gray-700 dark:bg-gray-700 dark:text-gray-300" },
                                                            "text": "$t:sirsoft-pay-nicepayments.admin.pay_status_cancelled"
                                                        },
                                                        {
                                                            "type": "basic",
                                                            "name": "Span",
                                                            "if": "{{_local._nicepayResult.PayStatus !== '0' && _local._nicepayResult.PayStatus !== '1'}}",
                                                            "props": { "className": "inline-flex items-center px-2 py-0.5 rounded-full text-xs font-semibold bg-amber-100 text-amber-800 dark:bg-amber-900/30 dark:text-amber-300" },
                                                            "text": "$t:sirsoft-pay-nicepayments.admin.pay_status_unknown"
                                                        }
                                                    ]
                                                },
                                                {
                                                    "type": "basic",
                                                    "name": "Dl",
                                                    "props": { "className": "grid grid-cols-2 gap-x-4 gap-y-1.5 text-xs" },
                                                    "children": [
                                                        {
                                                            "type": "basic",
                                                            "name": "Dt",
                                                            "props": { "className": "text-gray-500 dark:text-gray-400" },
                                                            "text": "$t:sirsoft-pay-nicepayments.admin.result_order_id"
                                                        },
                                                        {
                                                            "type": "basic",
                                                            "name": "Dd",
                                                            "props": { "className": "text-gray-900 dark:text-gray-100 font-mono" },
                                                            "text": "{{_local._nicepayResult.Moid ?? '-'}}"
                                                        },
                                                        {
                                                            "type": "basic",
                                                            "name": "Dt",
                                                            "props": { "className": "text-gray-500 dark:text-gray-400" },
                                                            "text": "$t:sirsoft-pay-nicepayments.admin.result_amount"
                                                        },
                                                        {
                                                            "type": "basic",
                                                            "name": "Dd",
                                                            "props": { "className": "text-gray-900 dark:text-gray-100" },
                                                            "text": "{{_local._nicepayResult.Amt ?? '-'}}"
                                                        },
                                                        {
                                                            "type": "basic",
                                                            "name": "Dt",
                                                            "props": { "className": "text-gray-500 dark:text-gray-400" },
                                                            "text": "$t:sirsoft-pay-nicepayments.admin.result_method"
                                                        },
                                                        {
                                                            "type": "basic",
                                                            "name": "Dd",
                                                            "props": { "className": "text-gray-900 dark:text-gray-100" },
                                                            "text": "{{_local._nicepayResult.PayMethod ?? '-'}}"
                                                        },
                                                        {
                                                            "type": "basic",
                                                            "name": "Dt",
                                                            "props": { "className": "text-gray-500 dark:text-gray-400" },
                                                            "text": "$t:sirsoft-pay-nicepayments.admin.result_result_code"
                                                        },
                                                        {
                                                            "type": "basic",
                                                            "name": "Dd",
                                                            "props": { "className": "font-mono text-gray-900 dark:text-gray-100" },
                                                            "text": "{{(_local._nicepayResult.ResultCode ?? '') + ' ' + (_local._nicepayResult.ResultMsg ?? '')}}"
                                                        }
                                                    ]
                                                }
                                            ]
                                        }
                                    ]
                                }
                            ]
                        }
                    ]
                },
                {
                    "id": "nicepay_vbank_notifications_panel",
                    "type": "basic",
                    "name": "Div",
                    "if": "{{(order.data?.payments?.filter(p => p.payment_method === 'vbank' && (p.payment_meta?.vbank_notifications ?? []).length > 0) ?? []).length > 0}}",
                    "props": { "className": "card mt-4" },
                    "children": [
                        {
                            "type": "basic",
                            "name": "Div",
                            "props": { "className": "flex items-center gap-2 mb-4" },
                            "children": [
                                { "type": "basic", "name": "Div", "props": { "className": "w-1.5 h-4 bg-emerald-500 rounded-full flex-shrink-0" } },
                                {
                                    "type": "basic", "name": "H3",
                                    "props": { "className": "text-sm font-semibold text-gray-800 dark:text-gray-200" },
                                    "text": "$t:sirsoft-pay-nicepayments.admin.vbank_noti_title"
                                },
                                {
                                    "type": "basic", "name": "Span",
                                    "props": { "className": "text-xs text-gray-400 dark:text-gray-500 hidden sm:inline" },
                                    "text": "$t:sirsoft-pay-nicepayments.admin.vbank_noti_description"
                                }
                            ]
                        },
                        {
                            "type": "basic",
                            "name": "Div",
                            "props": { "className": "space-y-4" },
                            "iteration": {
                                "source": "{{order.data?.payments?.filter(p => p.payment_method === 'vbank' && (p.payment_meta?.vbank_notifications ?? []).length > 0) ?? []}}",
                                "item_var": "payment",
                                "index_var": "pIdx"
                            },
                            "children": [
                                {
                                    "type": "basic",
                                    "name": "Div",
                                    "props": { "className": "border border-gray-200 dark:border-gray-700 rounded-lg p-3" },
                                    "children": [
                                        {
                                            "type": "basic",
                                            "name": "Dl",
                                            "props": { "className": "grid grid-cols-2 gap-x-4 gap-y-1.5 text-xs mb-3" },
                                            "children": [
                                                { "type": "basic", "name": "Dt", "props": { "className": "text-gray-500 dark:text-gray-400" }, "text": "$t:sirsoft-pay-nicepayments.admin.vbank_noti_count" },
                                                { "type": "basic", "name": "Dd", "props": { "className": "text-gray-900 dark:text-gray-100 font-semibold" }, "text": "{{(payment.payment_meta?.vbank_notification_summary?.count ?? 0) + '회'}}" },
                                                { "type": "basic", "name": "Dt", "props": { "className": "text-gray-500 dark:text-gray-400" }, "text": "$t:sirsoft-pay-nicepayments.admin.vbank_noti_first_at" },
                                                { "type": "basic", "name": "Dd", "props": { "className": "text-gray-900 dark:text-gray-100 font-mono" }, "text": "{{$formatDate(payment.payment_meta?.vbank_notification_summary?.first_received_at, 'YYYY-MM-DD HH:mm:ss') ?? '-'}}" },
                                                { "type": "basic", "name": "Dt", "props": { "className": "text-gray-500 dark:text-gray-400" }, "text": "$t:sirsoft-pay-nicepayments.admin.vbank_noti_last_at" },
                                                { "type": "basic", "name": "Dd", "props": { "className": "text-gray-900 dark:text-gray-100 font-mono" }, "text": "{{$formatDate(payment.payment_meta?.vbank_notification_summary?.last_received_at, 'YYYY-MM-DD HH:mm:ss') ?? '-'}}" },
                                                { "type": "basic", "name": "Dt", "props": { "className": "text-gray-500 dark:text-gray-400" }, "text": "$t:sirsoft-pay-nicepayments.admin.vbank_noti_deposited_at" },
                                                { "type": "basic", "name": "Dd", "props": { "className": "text-emerald-700 dark:text-emerald-400 font-mono" }, "text": "{{$formatDate(payment.payment_meta?.vbank_notification_summary?.deposited_at, 'YYYY-MM-DD HH:mm:ss') ?? '-'}}" },
                                                {
                                                    "type": "basic", "name": "Dt",
                                                    "if": "{{!!payment.payment_meta?.vbank_notification_summary?.cancelled_at}}",
                                                    "props": { "className": "text-gray-500 dark:text-gray-400" },
                                                    "text": "$t:sirsoft-pay-nicepayments.admin.vbank_noti_cancelled_at"
                                                },
                                                {
                                                    "type": "basic", "name": "Dd",
                                                    "if": "{{!!payment.payment_meta?.vbank_notification_summary?.cancelled_at}}",
                                                    "props": { "className": "text-rose-700 dark:text-rose-400 font-mono" },
                                                    "text": "{{$formatDate(payment.payment_meta?.vbank_notification_summary?.cancelled_at, 'YYYY-MM-DD HH:mm:ss')}}"
                                                },
                                                { "type": "basic", "name": "Dt", "props": { "className": "text-gray-500 dark:text-gray-400" }, "text": "$t:sirsoft-pay-nicepayments.admin.vbank_noti_depositor" },
                                                { "type": "basic", "name": "Dd", "props": { "className": "text-gray-900 dark:text-gray-100" }, "text": "{{payment.payment_meta?.vbank_notification_summary?.last_depositor ?? '-'}}" }
                                            ]
                                        },
                                        {
                                            "type": "basic",
                                            "name": "Div",
                                            "props": { "className": "border-t border-gray-200 dark:border-gray-700 pt-3" },
                                            "children": [
                                                {
                                                    "type": "basic", "name": "P",
                                                    "props": { "className": "text-xs font-semibold text-gray-700 dark:text-gray-300 mb-2" },
                                                    "text": "$t:sirsoft-pay-nicepayments.admin.vbank_noti_history"
                                                },
                                                {
                                                    "type": "basic",
                                                    "name": "Div",
                                                    "props": { "className": "space-y-1.5 text-xs" },
                                                    "iteration": {
                                                        "source": "{{payment.payment_meta?.vbank_notifications ?? []}}",
                                                        "item_var": "noti",
                                                        "index_var": "nIdx"
                                                    },
                                                    "children": [
                                                        {
                                                            "type": "basic",
                                                            "name": "Div",
                                                            "props": { "className": "flex items-center gap-2 py-1 border-b border-gray-100 dark:border-gray-800 last:border-0" },
                                                            "children": [
                                                                {
                                                                    "type": "basic", "name": "Span",
                                                                    "if": "{{noti.type === 'deposited'}}",
                                                                    "props": { "className": "inline-flex items-center px-2 py-0.5 rounded text-[10px] font-semibold bg-emerald-100 text-emerald-800 dark:bg-emerald-900/30 dark:text-emerald-300 flex-shrink-0" },
                                                                    "text": "$t:sirsoft-pay-nicepayments.admin.vbank_noti_type_deposited"
                                                                },
                                                                {
                                                                    "type": "basic", "name": "Span",
                                                                    "if": "{{noti.type === 'cancelled'}}",
                                                                    "props": { "className": "inline-flex items-center px-2 py-0.5 rounded text-[10px] font-semibold bg-rose-100 text-rose-800 dark:bg-rose-900/30 dark:text-rose-300 flex-shrink-0" },
                                                                    "text": "$t:sirsoft-pay-nicepayments.admin.vbank_noti_type_cancelled"
                                                                },
                                                                {
                                                                    "type": "basic", "name": "Span",
                                                                    "if": "{{noti.type !== 'deposited' && noti.type !== 'cancelled'}}",
                                                                    "props": { "className": "inline-flex items-center px-2 py-0.5 rounded text-[10px] font-semibold bg-gray-100 text-gray-700 dark:bg-gray-700 dark:text-gray-300 flex-shrink-0" },
                                                                    "text": "$t:sirsoft-pay-nicepayments.admin.vbank_noti_type_other"
                                                                },
                                                                {
                                                                    "type": "basic", "name": "Span",
                                                                    "props": { "className": "font-mono text-gray-700 dark:text-gray-300" },
                                                                    "text": "{{$formatDate(noti.received_at, 'YYYY-MM-DD HH:mm:ss')}}"
                                                                },
                                                                {
                                                                    "type": "basic", "name": "Span",
                                                                    "props": { "className": "text-gray-500 dark:text-gray-400 font-mono" },
                                                                    "text": "{{noti.result_code ?? '-'}}"
                                                                },
                                                                {
                                                                    "type": "basic", "name": "Span",
                                                                    "props": { "className": "text-gray-700 dark:text-gray-300" },
                                                                    "text": "{{noti.result_msg ?? ''}}"
                                                                },
                                                                {
                                                                    "type": "basic", "name": "Span",
                                                                    "if": "{{noti.depositor}}",
                                                                    "props": { "className": "ml-auto text-gray-600 dark:text-gray-400" },
                                                                    "text": "{{noti.depositor + ' / ' + (noti.amt ?? 0).toLocaleString() + '원'}}"
                                                                }
                                                            ]
                                                        }
                                                    ]
                                                }
                                            ]
                                        }
                                    ]
                                }
                            ]
                        }
                    ]
                }
            ]
        }
    ]
}
