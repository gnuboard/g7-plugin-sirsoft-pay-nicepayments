{
    "target_layout": "shop/checkout",
    "data_sources": [
        {
            "id": "nicepay_easy_pay_config",
            "type": "api",
            "endpoint": "/api/modules/sirsoft-ecommerce/payments/client-config/nicepayments",
            "method": "GET",
            "auto_fetch": true
        }
    ],
    "injections": [
        {
            "target_id": "nicepay_checkout_payment_section",
            "position": "append_child",
            "components": [
                {
                    "comment": "간편결제 섹션 - enabled_easy_pays 가 하나 이상인 경우에만 표시",
                    "type": "basic",
                    "name": "Div",
                    "if": "{{(nicepay_easy_pay_config.data?.enabled_easy_pays ?? []).length > 0}}",
                    "props": { "className": "mt-4 pt-4 border-t border-gray-200 dark:border-gray-700" },
                    "responsive": {
                        "portable": {
                            "props": { "className": "mt-3 pt-3 border-t border-gray-200 dark:border-gray-700" }
                        }
                    },
                    "children": [
                        {
                            "type": "basic",
                            "name": "P",
                            "props": { "className": "text-sm font-medium text-gray-700 dark:text-gray-300 mb-3" },
                            "responsive": {
                                "portable": {
                                    "props": { "className": "text-sm font-medium text-gray-700 dark:text-gray-300 mb-2" }
                                }
                            },
                            "text": "$t:sirsoft-pay-nicepayments.easy_pay.section_title"
                        },
                        {
                            "type": "basic",
                            "name": "Div",
                            "props": { "className": "flex flex-wrap gap-2" },
                            "children": [
                                {
                                    "comment": "네이버페이",
                                    "type": "basic",
                                    "name": "Button",
                                    "if": "{{(nicepay_easy_pay_config.data?.enabled_easy_pays ?? []).includes('NAVERPAY')}}",
                                    "props": {
                                        "type": "button",
                                        "className": "{{_computed.selectedPaymentMethod === 'nicepay_naverpay' ? 'px-4 py-2 rounded-lg text-sm font-bold bg-green-500 text-white ring-2 ring-offset-1 ring-green-500 shadow-md' : 'px-4 py-2 rounded-lg text-sm font-bold bg-green-500 text-white hover:opacity-90'}}"
                                    },
                                    "text": "네이버페이",
                                    "actions": [
                                        {
                                            "type": "click",
                                            "handler": "sirsoft-pay-nicepayments.setPaymentMethod",
                                            "params": { "paymentMethod": "nicepay_naverpay" }
                                        }
                                    ]
                                },
                                {
                                    "comment": "카카오페이",
                                    "type": "basic",
                                    "name": "Button",
                                    "if": "{{(nicepay_easy_pay_config.data?.enabled_easy_pays ?? []).includes('KAKAOPAY')}}",
                                    "props": {
                                        "type": "button",
                                        "className": "{{_computed.selectedPaymentMethod === 'nicepay_kakaopay' ? 'px-4 py-2 rounded-lg text-sm font-bold bg-yellow-400 text-gray-900 ring-2 ring-offset-1 ring-yellow-400 shadow-md' : 'px-4 py-2 rounded-lg text-sm font-bold bg-yellow-400 text-gray-900 hover:opacity-90'}}"
                                    },
                                    "text": "카카오페이",
                                    "actions": [
                                        {
                                            "type": "click",
                                            "handler": "sirsoft-pay-nicepayments.setPaymentMethod",
                                            "params": { "paymentMethod": "nicepay_kakaopay" }
                                        }
                                    ]
                                },
                                {
                                    "comment": "삼성페이",
                                    "type": "basic",
                                    "name": "Button",
                                    "if": "{{(nicepay_easy_pay_config.data?.enabled_easy_pays ?? []).includes('SAMSUNGPAY')}}",
                                    "props": {
                                        "type": "button",
                                        "className": "{{_computed.selectedPaymentMethod === 'nicepay_samsungpay' ? 'px-4 py-2 rounded-lg text-sm font-bold bg-blue-700 text-white ring-2 ring-offset-1 ring-blue-700 shadow-md' : 'px-4 py-2 rounded-lg text-sm font-bold bg-blue-700 text-white hover:opacity-90'}}"
                                    },
                                    "text": "삼성페이",
                                    "actions": [
                                        {
                                            "type": "click",
                                            "handler": "sirsoft-pay-nicepayments.setPaymentMethod",
                                            "params": { "paymentMethod": "nicepay_samsungpay" }
                                        }
                                    ]
                                },
                                {
                                    "comment": "애플페이",
                                    "type": "basic",
                                    "name": "Button",
                                    "if": "{{(nicepay_easy_pay_config.data?.enabled_easy_pays ?? []).includes('APPLEPAY')}}",
                                    "props": {
                                        "type": "button",
                                        "className": "{{_computed.selectedPaymentMethod === 'nicepay_applepay' ? 'px-4 py-2 rounded-lg text-sm font-bold bg-gray-900 dark:bg-gray-950 text-white ring-2 ring-offset-1 ring-gray-900 shadow-md' : 'px-4 py-2 rounded-lg text-sm font-bold bg-gray-900 dark:bg-gray-950 text-white hover:opacity-90'}}"
                                    },
                                    "text": "애플페이",
                                    "actions": [
                                        {
                                            "type": "click",
                                            "handler": "sirsoft-pay-nicepayments.setPaymentMethod",
                                            "params": { "paymentMethod": "nicepay_applepay" }
                                        }
                                    ]
                                },
                                {
                                    "comment": "PAYCO",
                                    "type": "basic",
                                    "name": "Button",
                                    "if": "{{(nicepay_easy_pay_config.data?.enabled_easy_pays ?? []).includes('PAYCO')}}",
                                    "props": {
                                        "type": "button",
                                        "className": "{{_computed.selectedPaymentMethod === 'nicepay_payco' ? 'px-4 py-2 rounded-lg text-sm font-bold bg-red-500 text-white ring-2 ring-offset-1 ring-red-500 shadow-md' : 'px-4 py-2 rounded-lg text-sm font-bold bg-red-500 text-white hover:opacity-90'}}"
                                    },
                                    "text": "PAYCO",
                                    "actions": [
                                        {
                                            "type": "click",
                                            "handler": "sirsoft-pay-nicepayments.setPaymentMethod",
                                            "params": { "paymentMethod": "nicepay_payco" }
                                        }
                                    ]
                                },
                                {
                                    "comment": "11pay (SKpay)",
                                    "type": "basic",
                                    "name": "Button",
                                    "if": "{{(nicepay_easy_pay_config.data?.enabled_easy_pays ?? []).includes('SKPAY')}}",
                                    "props": {
                                        "type": "button",
                                        "className": "{{_computed.selectedPaymentMethod === 'nicepay_skpay' ? 'px-4 py-2 rounded-lg text-sm font-bold bg-orange-500 text-white ring-2 ring-offset-1 ring-orange-500 shadow-md' : 'px-4 py-2 rounded-lg text-sm font-bold bg-orange-500 text-white hover:opacity-90'}}"
                                    },
                                    "text": "11pay",
                                    "actions": [
                                        {
                                            "type": "click",
                                            "handler": "sirsoft-pay-nicepayments.setPaymentMethod",
                                            "params": { "paymentMethod": "nicepay_skpay" }
                                        }
                                    ]
                                },
                                {
                                    "comment": "SSG페이",
                                    "type": "basic",
                                    "name": "Button",
                                    "if": "{{(nicepay_easy_pay_config.data?.enabled_easy_pays ?? []).includes('SSGPAY')}}",
                                    "props": {
                                        "type": "button",
                                        "className": "{{_computed.selectedPaymentMethod === 'nicepay_ssgpay' ? 'px-4 py-2 rounded-lg text-sm font-bold bg-red-600 text-white ring-2 ring-offset-1 ring-red-600 shadow-md' : 'px-4 py-2 rounded-lg text-sm font-bold bg-red-600 text-white hover:opacity-90'}}"
                                    },
                                    "text": "SSG페이",
                                    "actions": [
                                        {
                                            "type": "click",
                                            "handler": "sirsoft-pay-nicepayments.setPaymentMethod",
                                            "params": { "paymentMethod": "nicepay_ssgpay" }
                                        }
                                    ]
                                },
                                {
                                    "comment": "L.pay",
                                    "type": "basic",
                                    "name": "Button",
                                    "if": "{{(nicepay_easy_pay_config.data?.enabled_easy_pays ?? []).includes('LPAY')}}",
                                    "props": {
                                        "type": "button",
                                        "className": "{{_computed.selectedPaymentMethod === 'nicepay_lpay' ? 'px-4 py-2 rounded-lg text-sm font-bold bg-pink-700 text-white ring-2 ring-offset-1 ring-pink-700 shadow-md' : 'px-4 py-2 rounded-lg text-sm font-bold bg-pink-700 text-white hover:opacity-90'}}"
                                    },
                                    "text": "L.pay",
                                    "actions": [
                                        {
                                            "type": "click",
                                            "handler": "sirsoft-pay-nicepayments.setPaymentMethod",
                                            "params": { "paymentMethod": "nicepay_lpay" }
                                        }
                                    ]
                                }
                            ]
                        }
                    ]
                }
            ]
        }
    ]
}
